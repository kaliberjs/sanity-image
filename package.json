{
  "name": "@kaliber/sanity-image",
  "version": "1.3.2",
  "main": "index.js",
  "sideEffects": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sanity",
    "kaliber",
    "image"
  ],
  "files": [
    "index.js",
    "src/**",
    "LICENSE",
    "readme.md",
    "package.json"
  ],
  "private": false,
  "license": "MIT",
  "description": "Use Sanity images without worrying about srcSet, sizes, or any other of that stuff.",
  "repository": "https://github.com/kaliberjs/sanity-image.git",
  "scripts": {
    "postinstall": "[ -d ./scripts -a -f ./scripts/install-peer-dependencies-for-typescript.js ] && node ./scripts/install-peer-dependencies-for-typescript.js || true"
  },
  "peerDependencies": {
    "@kaliber/use-element-size": "^4.0.0",
    "@kaliber/use-observed-ref": "^1.0.0",
    "@sanity/image-url": "^2.0.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@kaliber/eslint-plugin": "^1.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0"
  }
}
