{
  "include": [
    "./index.js",
    "./src/**/*",
    "./scripts/**/*",
  ],
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "allowUmdGlobalAccess": true,
    "resolveJsonModule": true,
    "maxNodeModuleJsDepth": 3,
    "allowImportingTsExtensions": true,
    "paths": {
       "*": ["./node_modules/@types/*", "./typescript/node_modules/*"]
    }
  }
}
